# =============================================
# Vinayaka Chavithi App - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-very-secret-key-change-this-in-production-minimum-32-chars
FLASK_ENV=development
FLASK_DEBUG=0

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vinayaka_chavithi_db
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# Admin Setup (used for initial admin creation)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
ADMIN_EMAIL=admin@yoursite.com

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=static/images/uploads

# Festival Date (YYYY-MM-DD HH:MM:SS) - Update each year
FESTIVAL_DATE=2025-08-27 06:00:00
